{
  "name": "worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "tsx --test \"test/**/*.test.ts\"",
    "test:coverage": "c8 --reporter=text --reporter=lcov --check-coverage --statements 95 --branches 95 --functions 95 --lines 95 tsx --test \"test/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "hono": "^4.8.3",
    "jose": "^6.0.11",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250613.0",
    "@types/node": "^24.0.3",
    "c8": "^10.1.3",
    "eslint": "^9.29.0",
    "tsx": "^4.20.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.34.1",
    "wrangler": "^4.20.0"
  }
}
